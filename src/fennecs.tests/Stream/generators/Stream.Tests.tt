    [Theory]
    [ClassData(typeof(StreamCountGenerator))]
    public void All_Runners_Applicable(int count, bool createEmptyTable)
    {
        using var world = new World();

        var stream = world.Query<<#= types #>>().Stream();

        //Create an empty table by spawning and despawning a single entity
        //that matches our test Query (but is a larger Archetype)
        if (createEmptyTable)
        {
            var dead = world.Spawn()<#= AddChain(T, n, i => "0") #>.Add(0.25f);
            world.Despawn(dead);
        }

        for (var index = 0; index < count; index++)
        {
            Assert.Equal(index, stream.Count);
            world.Spawn()<#= AddChain(T, n, i => i == L ? "1" : "index") #>;
        }

        stream.For((<#= RefArgs(n, L) #>) =>
        {
            Assert.Equal(1, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(2);
        });

        stream.Raw((<#= MemArgs(n, 0, L) #>) =>
        {
            for (var i = 0; i < count; i++)
            {
<# if (n > 1) { #>
                Assert.Equal(i, mem0.Span[i].Value);
<# } #>
                Assert.Equal(2, <#= mL #>.Span[i].Value);
                <#= mL #>.Span[i] = <#= TL #>.New(3);
            }
        });

        stream.Raw((<#= MemArgs(n, 0, L) #>) =>
        {
            for (var i = 0; i < count; i++)
            {
<# if (n > 1) { #>
                Assert.Equal(i, mem0.Span[i].Value);
<# } #>
                Assert.Equal(3, <#= mL #>.Span[i].Value);
                <#= mL #>.Span[i] = <#= TL #>.New(4);
            }
        });

        stream.Job((<#= RefArgs(n, L) #>) =>
        {
            Assert.Equal(4, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(5);
        });

        stream.Job(6, (uniform, <#= RefArgs(n, L) #>) =>
        {
            Assert.Equal(5, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(uniform);
        });

        stream.For(7, (uniform, <#= RefArgs(n, L) #>) =>
        {
            Assert.Equal(6, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(uniform);
        });

        stream.Raw(8, (uniform, <#= MemArgs(n, L) #>) =>
        {
            for (var i = 0; i < count; i++)
            {
                Assert.Equal(7, <#= mL #>.Span[i].Value);
                <#= mL #>.Span[i] = <#= TL #>.New(uniform);
            }
        });

        stream.Raw(9, (uniform, <#= MemArgs(n, L) #>) =>
        {
            for (var i = 0; i < count; i++)
            {
                Assert.Equal(8, <#= mL #>.Span[i].Value);
                <#= mL #>.Span[i] = <#= TL #>.New(uniform);
            }
        });

        stream.For((in e, <#= RefArgs(n, L) #>) =>
        {
            Assert.True(e.Alive);
            Assert.Equal(9, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(10);
        });

        stream.For(11, (uniform, in _, <#= RefArgs(n, L) #>) =>
        {
            Assert.Equal(10, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(uniform);
        });

        stream.For((<#= RefArgs(n, L) #>) => { Assert.Equal(11, <#= cL #>.Value); });
    }


    [Theory]
    [ClassData(typeof(StreamCountGenerator))]
    public void Query_Count_Accurate(int count, bool createEmptyTable)
    {
        using var world = new World();

        if (createEmptyTable)
        {
            var dead = world.Spawn()<#= AddChain(T, n, i => "0") #>.Add(0.25f);
            world.Despawn(dead);
        }

        List<Entity> entities = new(count);

        var stream = world.Query<<#= types #>>().Stream();
        Assert.Equal(0, stream.Count);

        for (var index = 0; index < count; index++)
        {
            Assert.Equal(index, stream.Count);
            entities.Add(world.Spawn()<#= AddChain(T, n, i => "index") #>);
        }

        Assert.Equal(count, stream.Count);

        var random = new Random(69 + count);

        for (var i = count; i > 0; i--)
        {
            Assert.Equal(i, stream.Count);
            var removalIndex = random.Next(entities.Count);
            var removalEntity = entities[removalIndex];
            entities.RemoveAt(removalIndex);
            world.Despawn(removalEntity);
        }

        Assert.Equal(0, stream.Count);
    }


    [Theory]
    [ClassData(typeof(StreamCountGenerator))]
    public void Query_Raw_Count_Accurate(int count, bool createEmptyTable)
    {
        using var world = new World();

        if (createEmptyTable)
        {
            var dead = world.Spawn()<#= AddChain(T, n, i => "0") #>.Add(0.25f);
            world.Despawn(dead);
        }

        List<Entity> entities = new(count);

        var stream = world.Query<<#= types #>>().Stream();

        stream.Raw((<#= MemArgs(n, 0) #>) => { Assert.Equal(0, mem0.Length); });

        for (var index = 0; index < count; index++)
        {
            var captured = index;
            stream.Raw((<#= MemArgs(n, 0) #>) => { Assert.Equal(captured, mem0.Length); });

            entities.Add(world.Spawn()<#= AddChain(T, n, i => "index") #>);
        }

        stream.Raw((<#= MemArgs(n, 0) #>) => { Assert.Equal(count, mem0.Length); });

        var random = new Random(69 + count);

        for (var i = count; i > 0; i--)
        {
            var captured = i;
            stream.Raw((<#= MemArgs(n, 0) #>) => { Assert.Equal(captured, mem0.Length); });

            var removalIndex = random.Next(entities.Count);
            var removalEntity = entities[removalIndex];
            entities.RemoveAt(removalIndex);
            world.Despawn(removalEntity);
        }

        stream.Raw((<#= MemArgs(n, 0) #>) => { Assert.Equal(0, mem0.Length); });
    }


    [Theory]
    [ClassData(typeof(StreamCountGenerator))]
    public void Job_Visits_All_Entities(int count, bool createEmptyTable)
    {
        using var world = new World();

        if (createEmptyTable)
        {
            var dead = world.Spawn()<#= AddChain(T, n, i => "0") #>.Add(0.25f);
            world.Despawn(dead);
        }

        for (var index = 0; index < count; index++)
            world.Spawn()<#= AddChain(T, n, i => n > 1 && i == L ? "7" : "index") #>;

        var stream = world.Query<<#= types #>>().Stream();

        var processed = 0;
        stream.Job((<#= n > 1 ? RefArgs(n, 0, L) : RefArgs(n, 0) #>) =>
        {
            Interlocked.Increment(ref processed);
            c0 = <#= T0 #>.New(123);
<# if (n > 1) { #>
            Assert.Equal(7, <#= cL #>.Value);
            <#= cL #> = <#= TL #>.New(9);
<# } #>
        });

        Assert.Equal(count, processed);

        stream.Job((<#= n > 1 ? RefArgs(n, 0, L) : RefArgs(n, 0) #>) =>
        {
            Assert.Equal(123, c0.Value);
<# if (n > 1) { #>
            Assert.Equal(9, <#= cL #>.Value);
<# } #>
        });
    }


    [Theory]
    [ClassData(typeof(StreamCountGenerator))]
    public void Raw_Visits_All_Entities(int count, bool createEmptyTable)
    {
        using var world = new World();

        if (createEmptyTable)
        {
            var dead = world.Spawn()<#= AddChain(T, n, i => "0") #>.Add(0.25f);
            world.Despawn(dead);
        }

        for (var c = 0; c < count; c++)
            world.Spawn()<#= AddChain(T, n, i => i == 0 ? "c" : "0") #>;

        var stream = world.Query<<#= types #>>().Stream();

        stream.Raw((<#= MemArgs(n, 0, L) #>) =>
        {
            for (var i = 0; i < count; i++)
            {
                Assert.Equal(i, mem0.Span[i].Value);
                <#= mL #>.Span[i] = <#= TL #>.New(i + count);
            }
        });

        stream.Raw((<#= n > 1 ? MemArgs(n, 0, L) : MemArgs(n, 0) #>) =>
        {
            for (var i = 0; i < count; i++)
            {
<# if (n > 1) { #>
                Assert.Equal(i, mem0.Span[i].Value);
<# } #>
                Assert.Equal(i + count, <#= mL #>.Span[i].Value);
            }
        });
    }


    [Theory]
    [ClassData(typeof(StreamCountGenerator))]
    public void Run_Visits_All_Entities_in_Order(int count, bool createEmptyTable)
    {
        using var world = new World();

        if (createEmptyTable)
        {
            var dead = world.Spawn()<#= AddChain(T, n, i => "0") #>.Add(0.25f);
            world.Despawn(dead);
        }

        for (var c = 0; c < count; c++)
            world.Spawn()<#= AddChain(T, n, i => "0") #>;

        var stream = world.Query<<#= types #>>().Stream();

        var processed = 0;
        stream.Raw((<#= MemArgs(n, L) #>) =>
        {
            foreach (ref var value in <#= mL #>.Span) value = <#= TL #>.New(processed++);
        });

        Assert.Equal(count, processed);

        stream.Raw((<#= MemArgs(n, L) #>) =>
        {
            Assert.Equal(count, <#= mL #>.Length);
            for (var i = 0; i < count; i++) Assert.Equal(i, <#= mL #>.Span[i].Value);
        });

        var index = 0;
        stream.For((<#= RefArgs(n, L) #>) => { Assert.Equal(index++, <#= cL #>.Value); });

        var index2 = 0;
        stream.For(1337, (_, <#= RefArgs(n, L) #>) => { Assert.Equal(index2++, <#= cL #>.Value); });
    }


    [Fact]
    public void Can_Loop_With_Entity()
    {
        using var world = new World();

        var e1 = world.Spawn()<#= AddChain(T, n, i => "123") #>;
        var e2 = world.Spawn()<#= AddChain(T, n, i => "555") #>;

        var stream = world.Query<<#= types #>>().Stream();

        var found = new List<Entity>();

        stream.For((in e, <#= RefArgs(n) #>) =>
        {
            found.Add(e);
        });

        Assert.Equal(2, found.Count);
        Assert.Contains(e1, found);
        Assert.Contains(e2, found);
    }


    [Fact]
    public void Can_Loop_With_Entity_and_Uniform()
    {
        using var world = new World();

        var e1 = world.Spawn()<#= AddChain(T, n, i => "123") #>;
        var e2 = world.Spawn()<#= AddChain(T, n, i => "555") #>;

        var stream = world.Query<<#= types #>>().Stream();

        var found = new List<Entity>();

        stream.For(3.1415f, (uniform, in e, <#= RefArgs(n) #>) =>
        {
            found.Add(e);
            Assert.Equal(3.1415f, uniform);
        });

        Assert.Equal(2, found.Count);
        Assert.Contains(e1, found);
        Assert.Contains(e2, found);
    }


    [Fact]
    public void Cannot_Run_Job_on_Wildcard_Query()
    {
        using var world = new World();
        world.Spawn()<#= AddChain(T, n, i => i.ToString()) #>;

        var stream = world.Query<<#= types #>>(Match.Any).Stream();
        Assert.Throws<InvalidOperationException>(() => stream.Job((<#= RefArgs(n, 0) #>) => { output.WriteLine(c0.Value.ToString()); }));

        stream = world.Query<<#= types #>>(Match.Entity).Stream();
        Assert.Throws<InvalidOperationException>(() => stream.Job((<#= RefArgs(n, 0) #>) => { output.WriteLine(c0.Value.ToString()); }));

        stream = world.Query<<#= types #>>(Match.Target).Stream();
        Assert.Throws<InvalidOperationException>(() => stream.Job((<#= RefArgs(n, 0) #>) => { output.WriteLine(c0.Value.ToString()); }));

        stream = world.Query<<#= types #>>(Match.Object).Stream();
        Assert.Throws<InvalidOperationException>(() => stream.Job((<#= RefArgs(n, 0) #>) => { output.WriteLine(c0.Value.ToString()); }));

        stream = world.Query<<#= types #>>(Match.Plain).Stream();
        var ran = false;
        stream.Job((<#= RefArgs(n, 0) #>) =>
        {
            output.WriteLine(c0.Value.ToString());
            ran = true;
        });
        Assert.True(ran);
    }


    [Fact]
    public void Can_Warmup()
    {
        using var world = new World();
        var stream = world.Query<<#= types #>>().Stream();
        stream.Query.Warmup();
    }


    [Fact]
    public void Has_Batch_Interface()
    {
        using var world = new World();

        world.Spawn()<#= AddChain(T, n, i => i.ToString()) #>;

        var stream = world.Query<<#= types #>>().Not<string>().Stream();
        var batch = stream.Batch();
        batch.Add<string>("visited");
        batch.Submit();

        var check = world.Query<<#= types #>>().Compile();
        var i = 0;
        foreach (var entity in check)
        {
            i++;
            Assert.True(entity.Has<string>());
        }
        Assert.Equal(1, i);
    }
}
