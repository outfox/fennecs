<# for (var j = 0; j < n; j++) { #>

        // filter on component <#= j #> (<#= T[j] #>)
        var top<#= j #> = all.Where((in <#= T[j] #> c) => c.Value > 50);
        var bot<#= j #> = all.Where((in <#= T[j] #> c) => c.Value <= 50);

        var topCount<#= j #> = 0;
        var botCount<#= j #> = 0;
        top<#= j #>.For((<#= RefArgs(n, j) #>) =>
