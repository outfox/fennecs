            values<#= i #>[i] = <#= Tpl[i] #>.New(i * 10 + <#= i #>);
<# } #>
        }

        var wave = new Entity[count];
        Assert.Same(template, template.Spawn(wave, <#= string.Join(", ", Enumerable.Range(0, n).Select(i => $"values{i}")) #>));

