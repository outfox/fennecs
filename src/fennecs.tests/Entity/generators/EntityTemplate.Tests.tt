    [Fact]
    public void Single_Spawn_Provides_Required_Values()
    {
        using var world = new World();
        using var template = Template(world);

        var entity = template.Spawn(<#= Vals(n, i => (i * 10).ToString()) #>);

        Assert.True(entity.Alive);
<# for (var i = 0; i < n; i++) { #>
        Assert.Equal(<#= Tpl[i] #>.New(<#= i * 10 #>), entity.Ref<<#= Tpl[i] #>>());
<# } #>
    }


    [Fact]
    public void Uniform_Bulk_Spawn_Shares_Values()
    {
        using var world = new World();
        using var template = Template(world);

        Assert.Same(template, template.Spawn(5, <#= Vals(n, i => (i + 1).ToString()) #>));
        Assert.Equal(5, world.Count);
        foreach (var entity in world)
        {
<# for (var i = 0; i < n; i++) { #>
            Assert.Equal(<#= Tpl[i] #>.New(<#= i + 1 #>), entity.Ref<<#= Tpl[i] #>>());
<# } #>
        }

        // zero and negative counts spawn nothing
        template.Spawn(0, <#= Vals(n, _ => "9") #>);
        template.Spawn(-3, <#= Vals(n, _ => "9") #>);
        Assert.Equal(5, world.Count);
    }


    [Fact]
    public void Uniform_Span_Spawn_Delivers_Handles()
    {
        using var world = new World();
        using var template = Template(world);

        var wave = new Entity[4];
        Assert.Same(template, template.Spawn(wave, <#= Vals(n, i => (i + 2).ToString()) #>));

        foreach (var entity in wave)
        {
            Assert.True(entity.Alive);
<# for (var i = 0; i < n; i++) { #>
            Assert.Equal(<#= Tpl[i] #>.New(<#= i + 2 #>), entity.Ref<<#= Tpl[i] #>>());
<# } #>
        }

        // empty destination spawns nothing
        template.Spawn(Span<Entity>.Empty, <#= Vals(n, _ => "9") #>);
        Assert.Equal(4, world.Count);
    }


    [Fact]
    public void Factory_Spawn_Provides_Per_Entity_Values()
    {
        using var world = new World();
        using var template = Template(world);

        Assert.Same(template, template.Spawn(7, i => <#= factoryBody #>));
        Assert.Equal(7, world.Count);

        var seen = new HashSet<int>();
        foreach (var entity in world)
        {
            var index = entity.Ref<TplA>().Value;
            Assert.True(seen.Add(index));
<# for (var i = 1; i < n; i++) { #>
            Assert.Equal(<#= Tpl[i] #>.New(index + <#= i #>), entity.Ref<<#= Tpl[i] #>>());
<# } #>
        }
        Assert.Equal(Enumerable.Range(0, 7).ToHashSet(), seen);

        // zero count spawns nothing, null factory throws
        template.Spawn(0, i => <#= factoryBody #>);
        Assert.Equal(7, world.Count);
        Assert.Throws<ArgumentNullException>(() => template.Spawn(5, (<#= factoryType #>)null!));
    }


    [Fact]
    public void Factory_Span_Spawn_Delivers_Handles()
    {
        using var world = new World();
        using var template = Template(world);

        var wave = new Entity[6];
        Assert.Same(template, template.Spawn(wave, i => <#= factoryBody #>));

        for (var i = 0; i < wave.Length; i++)
