<#
    const int MaxArity = 6; // must match EntityTemplate.tt in the fennecs library

    // Required component type per arity slot.
    var Tpl = new[] { "TplA", "TplB", "TplC", "TplD", "TplE", "TplF" };

    // "TplA, TplB" for n = 2
    string TypeList(int n) => string.Join(", ", Tpl.Take(n));

    // ".Needs<TplA>().Needs<TplB>()" for n = 2
    string NeedsChain(int n) => string.Concat(Enumerable.Range(0, n).Select(i => $".Needs<{Tpl[i]}>()"));

    // "TplA.New(f(0)), TplB.New(f(1))" for n = 2
    string Vals(int n, Func<int, string> f) => string.Join(", ", Enumerable.Range(0, n).Select(i => $"{Tpl[i]}.New({f(i)})"));
#>
