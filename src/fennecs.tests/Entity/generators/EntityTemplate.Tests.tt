<# } #>
        }

        // empty destination spawns nothing, null factory throws
        template.Spawn(Span<Entity>.Empty, i => <#= factoryBody #>);
        Assert.Equal(6, world.Count);
        Assert.Throws<ArgumentNullException>(() =>
        {
            var destination = new Entity[3];
            template.Spawn(destination, (<#= factoryType #>)null!);
        });
    }


